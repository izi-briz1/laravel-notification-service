<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!-- Интеграционные тесты гоняются против реальных PostgreSQL и Redis
             из docker-compose. force="true" пишет только в $_ENV/putenv, а
             env() Laravel читает $_SERVER (реальное окружение контейнера)
             раньше — выравнивание делает tests/TestCase.php -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="redis" force="true"/>
        <env name="REDIS_CACHE_DB" value="9" force="true"/>
        <env name="REDIS_DB" value="8" force="true"/>
        <env name="DB_CONNECTION" value="pgsql" force="true"/>
        <env name="DB_DATABASE" value="notifications_test" force="true"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="FAKE_PROVIDER_TRANSIENT_FAILURE_PERCENT" value="0" force="true"/>
        <env name="FAKE_PROVIDER_PERMANENT_FAILURE_PERCENT" value="0" force="true"/>
        <env name="FAKE_PROVIDER_AUTO_CONFIRM" value="false" force="true"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
